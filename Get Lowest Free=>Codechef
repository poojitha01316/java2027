class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc = new Scanner(System.in);
		if (sc.hasNextInt()) {
		    int t = sc.nextInt();
		    
		    while (t-- > 0) {
		        int a = sc.nextInt();
		        int b = sc.nextInt();
		        int c = sc.nextInt();
		   
		        int minPrice = Math.min(a, Math.min(b, c));

		        int amountToPay = (a + b + c) - minPrice;
		        
		        System.out.println(amountToPay);
		    }
		}
	}
}
