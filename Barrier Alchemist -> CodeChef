import java.util.Scanner;

class Codechef {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int t = scanner.nextInt();
        while (t-- > 0) {
            int N = scanner.nextInt();
            int H = scanner.nextInt();
            int Y1 = scanner.nextInt();
            int Y2 = scanner.nextInt();
            int L = scanner.nextInt();
            
            int barriersCrossed = 0;
            boolean exhausted = false;

            for (int i = 0; i < N; i++) {
                int type = scanner.nextInt();
                int X = scanner.nextInt();
                
                if (exhausted) {
                    // If already exhausted, just consume the rest of the input for this test case
                    continue;
                }

                boolean canPass = false;

                if (type == 1) {
                    // Type 1 barrier: starts at height X, extends up.
                    // Edward needs his height after ducking (H - Y1) to be less than or equal to X.
                    // If (H - Y1) > X, he cannot pass by ducking, and he cannot pass by jumping 
                    // because the barrier extends to the sky. He must break it.
                    if (H - Y1 <= X) {
                        canPass = true;
                    }
                } else { // type == 2
                    // Type 2 barrier: starts at ground, extends up to height X.
                    // Edward needs his height after jumping (Y2) to be greater than or equal to X.
                    // If Y2 < X, he cannot pass by jumping, and he cannot pass by ducking 
                    // because the barrier starts from the ground. He must break it.
                    if (Y2 >= X) {
                        canPass = true;
                    }
                }

                if (canPass) {
                    barriersCrossed++;
                } else {
                    // Cannot pass naturally, must use life force to break it
                    if (L > 0) {
                        L--;
                        barriersCrossed++;
                        if (L == 0) {
                            // He used his last life force to break this barrier, but he is now exhausted
                            // and cannot pass the *next* barrier. He successfully passed this one.
                        }
                    } else {
                        // L is 0, cannot break, he stops here.
                        exhausted = true;
                    }
                }
                
                if (exhausted) {
                    // Stop counting if exhausted
                    break;
                }
            }
            
            System.out.println(barriersCrossed);
        }
        scanner.close();
    }
}
