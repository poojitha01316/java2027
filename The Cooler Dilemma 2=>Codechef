import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc = new Scanner(System.in);
		if (sc.hasNextInt()) {
		    int T = sc.nextInt();
		    while (T-- > 0) {
		        long X = sc.nextLong();
		        long Y = sc.nextLong();
		        long maxMonths = (Y - 1) / X;
		        if (maxMonths < 0) {
		            System.out.println(0);
		        } else {
		            System.out.println(maxMonths);
		        }
		    }
		}
	}
}
