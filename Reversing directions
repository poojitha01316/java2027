Input
Output
2
4
Begin on Road A
Right on Road B
Right on Road C
Left on Road D
6
Begin on Old Madras Road
Left on Domlur Flyover
Left on 100 Feet Road
Right on Sarjapur Road
Right on Hosur Road
Right on Ganapathi Temple Road
Begin on Road D
Right on Road C
Left on Road B
Left on Road A
Begin on Ganapathi Temple Road
Left on Hosur Road
Left on Sarjapur Road
Left on 100 Feet Road
Right on Domlur Flyover
Right on Old Madras Road

Explanation:
In the first test case, the destination lies on Road D, hence the reversed route begins on Road D. The final turn in the original route is turning left from Road C onto Road D. The reverse of this, turning right from Road D onto Road C, is the first turn in the reversed route.

import java.util.*;
import java.io.*;

class Codechef {
    public static void main(String[] args) throws java.lang.Exception {
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        int t = Integer.parseInt(br.readLine());
        StringBuilder output = new StringBuilder();

        while (t-- > 0) {
            int n = Integer.parseInt(br.readLine());
            String[] instructions = new String[n];
            for (int i = 0; i < n; i++) {
                instructions[i] = br.readLine();
            }
            String lastInstruction = instructions[n - 1];
            String[] parts = lastInstruction.split(" ", 3);
            String lastRoad = parts[2];
            
            output.append("Begin on ").append(lastRoad).append("\n");
            for (int i = n - 2; i >= 1; i--) {
                String originalInstruction = instructions[i];
                // REMOVED ERROR: parts[2]="Road C"
                String[] instructionParts = originalInstruction.split(" ", 3);
                String turn = instructionParts[0];
                String road = instructionParts[2];
                
                String reversedTurn;
                if (turn.equals("Left")) {
                    reversedTurn = "Right";
                } else { 
                    reversedTurn = "Left";
                }
                
                output.append(reversedTurn).append(" on ").append(road).append("\n");
            }
            
            String firstInstruction = instructions[0];
            String[] parts0 = firstInstruction.split(" ", 3); 
            String roadA = parts0[2];
            
            // FIX: Added the logic to print the final reversed instruction (on Road A)
            if (n > 1) {
                String secondInstruction = instructions[1];
                String[] parts1 = secondInstruction.split(" ", 3);
                String turn1 = parts1[0];
                
                String finalReversedTurn;
                if (turn1.equals("Left")) {
                    finalReversedTurn = "Right";
                } else {
                    finalReversedTurn = "Left";
                }
                output.append(finalReversedTurn).append(" on ").append(roadA).append("\n");
            }
            
            if (t > 0) {
                output.append("\n");
            }
        }
        
        System.out.print(output.toString());
    }
}
