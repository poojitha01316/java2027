import java.util.*;
import java.io.*;

class Codechef {
    public static void solve() {
        try (Scanner scanner = new Scanner(System.in)) {
            if (!scanner.hasNextInt()) return;
            int N = scanner.nextInt();
            
            long[] A = new long[N];
            for (int i = 0; i < N; i++) {
                A[i] = scanner.nextLong();
            }
            
            // 1. Calculate Prefix Sums
            // P[i] will store the sum of A[0] through A[i-1]. P size N+1.
            // P[0] = 0
            // P[k] = sum of first k tasks (tasks 1 to k)
            long[] P = new long[N + 1];
            P[0] = 0;
            for (int i = 0; i < N; i++) {
                P[i + 1] = P[i] + A[i];
            }
            
            long totalSum = P[N];
            long minTime = totalSum; // Initialize with the worst case (one processor handles all)

            // 2. Iterate through all possible split points k (0 to N)
            // k represents the number of tasks assigned to Processor 1.
            // k=0: P1 gets 0 tasks, P2 gets N tasks. Time = max(P[0], Total - P[0]) = max(0, totalSum)
            // k=N: P1 gets N tasks, P2 gets 0 tasks. Time = max(P[N], Total - P[N]) = max(totalSum, 0)
            
            for (int k = 0; k <= N; k++) {
                long timeP1 = P[k]; // Sum of first k tasks
                long timeP2 = totalSum - P[k]; // Sum of remaining N-k tasks
                
                long currentTime = Math.max(timeP1, timeP2);
                minTime = Math.min(minTime, currentTime);
            }
            
            System.out.println(minTime);

        } catch (Exception e) {
            // Handle potential exceptions if necessary
        }
    }

    public static void main(String[] args) throws java.lang.Exception {
        try (BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
             PrintWriter out = new PrintWriter(System.out)) {
            
            int T = Integer.parseInt(br.readLine());
            while (T-- > 0) {
                int N = Integer.parseInt(br.readLine());
                String[] parts = br.readLine().split(" ");
                
                long[] A = new long[N];
                for (int i = 0; i < N; i++) {
                    A[i] = Long.parseLong(parts[i]);
                }
                
                // Using fast I/O approach within the main loop
                long[] P = new long[N + 1];
                P[0] = 0;
                for (int i = 0; i < N; i++) {
                    P[i + 1] = P[i] + A[i];
                }
                
                long totalSum = P[N];
                long minTime = totalSum; 

                for (int k = 0; k <= N; k++) {
                    long timeP1 = P[k]; 
                    long timeP2 = totalSum - P[k]; 
                    
                    long currentTime = Math.max(timeP1, timeP2);
                    minTime = Math.min(minTime, currentTime);
                }
                
                out.println(minTime);
            }
            out.flush();
        }
    }
}
